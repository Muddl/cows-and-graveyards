[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/TutorialOverlay.cs" id="tutorial_overlay_script"]
[ext_resource type="Theme" path="res://assets/ui/game_theme.tres" id="game_theme"]

[node name="TutorialOverlay" type="Control"]
layout_mode = 3
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 0
theme = ExtResource("game_theme")
script = ExtResource("tutorial_overlay_script")

[node name="Dimmer" type="ColorRect" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.6)
mouse_filter = 2

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchor_left = 0.1
anchor_top = 0.3
anchor_right = 0.9
anchor_bottom = 0.7
mouse_filter = 2

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2

[node name="StepLabel" type="Label" parent="Panel"]
layout_mode = 2
text = "Tap the left side to count cows on your side!"
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 2
theme_override_font_sizes/font_size = 40

[node name="NextButton" type="Button" parent="Panel"]
layout_mode = 2
size_flags_vertical = 8
text = "Next"
theme_override_font_sizes/font_size = 36
