[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/GraveyardTooltip.cs" id="graveyard_tooltip_script"]
[ext_resource type="Theme" path="res://assets/ui/game_theme.tres" id="game_theme"]

[node name="GraveyardTooltip" type="Control"]
layout_mode = 3
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 0
visible = false
theme = ExtResource("game_theme")
script = ExtResource("graveyard_tooltip_script")

[node name="Dimmer" type="ColorRect" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.5)
mouse_filter = 2

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
anchor_left = 0.1
anchor_top = 0.35
anchor_right = 0.9
anchor_bottom = 0.65
mouse_filter = 2

[node name="MessageLabel" type="Label" parent="Panel"]
layout_mode = 2
text = "Pressing Graveyard resets your opponent\u2019s cow count to zero! Use it when you pass a graveyard."
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 2
theme_override_font_sizes/font_size = 36

[node name="GotItButton" type="Button" parent="Panel"]
layout_mode = 2
size_flags_vertical = 8
text = "Got it!"
theme_override_font_sizes/font_size = 36
